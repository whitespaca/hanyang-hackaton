{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["UV_CACHE_DIR"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "api#build": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
